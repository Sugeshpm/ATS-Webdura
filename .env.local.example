# Copy to .env.local and fill in. Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Service role key (server-only — NEVER expose to client). Used for admin/maintenance scripts only.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Local app URL (used for auth redirects in dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
