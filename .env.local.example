# Copy to .env.local and fill in. Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Service role key (server-only — NEVER expose to client). Used for admin/maintenance scripts only.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Local app URL (used for auth redirects in dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Meta (Facebook + Instagram) Lead Ads integration ---
# App ID + secret from https://developers.facebook.com/apps → your app → Settings → Basic
META_APP_ID=
META_APP_SECRET=

# Self-chosen random string. Meta sends it during the webhook verification handshake.
# Generate a strong one: `openssl rand -hex 32`
META_WEBHOOK_VERIFY_TOKEN=

# 32-byte key (64 hex chars) used to encrypt Page access tokens at rest.
# Generate: `openssl rand -hex 32`
META_ENCRYPTION_KEY=

# Optional: pin Graph API version (default is v20.0).
META_GRAPH_API_VERSION=v20.0
